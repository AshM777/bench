# Slack — get these from api.slack.com/apps
SLACK_BOT_TOKEN=xoxb-
SLACK_APP_TOKEN=xapp-
SLACK_SIGNING_SECRET=

# AWS Bedrock — used for Claude (responses + classification)
# Option A: set these directly
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Option B: leave blank if already configured via `aws configure`

# Supabase — create a free project at supabase.com
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Google Sheets — OAuth2 refresh token with drive.readonly scope
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# Bench config
WORKSPACE_NAME=
# Comma-separated list of sheets to ingest: spreadsheetId:Sheet Name
# Example: 1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgVE2upms:DAU Tracker,abc123:Release Log
SHEETS_CONFIG=

# Proactive engine
PROACTIVE_CONFIDENCE_THRESHOLD=0.75
