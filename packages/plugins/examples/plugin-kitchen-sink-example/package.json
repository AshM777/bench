{
  "name": "@bench/plugin-kitchen-sink-example",
  "version": "0.1.0",
  "description": "Reference plugin that demonstrates the full Bench plugin surface area in one package",
  "type": "module",
  "private": true,
  "exports": {
    ".": "./src/index.ts"
  },
  "benchPlugin": {
    "manifest": "./dist/manifest.js",
    "worker": "./dist/worker.js",
    "ui": "./dist/ui/"
  },
  "scripts": {
    "prebuild": "pnpm --filter @bench/plugin-sdk ensure-build-deps",
    "build": "tsc && node ./scripts/build-ui.mjs",
    "clean": "rm -rf dist",
    "typecheck": "pnpm --filter @bench/plugin-sdk ensure-build-deps && tsc --noEmit"
  },
  "dependencies": {
    "@bench/plugin-sdk": "workspace:*",
    "@bench/shared": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "esbuild": "^0.27.7",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "react": ">=18"
  }
}
